# Database Configuration
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://localhost/ivr_db

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Plivo Configuration
# Get these from your Plivo account dashboard
PLIVO_AUTH_ID=your_auth_id_here
PLIVO_AUTH_TOKEN=your_auth_token_here
PLIVO_PHONE_NUMBER=+15551234567

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# IVR Settings
DEFAULT_TIMEOUT=5
MAX_RETRIES=3
SESSION_TTL=1800

# Transfer Numbers (for call forwarding)
SALES_TRANSFER_NUMBER=+1234567890
SUPPORT_TRANSFER_NUMBER=+1234567890

# Webhook Base URL (your ngrok or public URL)
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.dev
