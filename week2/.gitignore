# ============================================================
# Week 2: AI Agents - Git Ignore File
# ============================================================
# This file tells git what NOT to push to GitHub

# ============================================================
# CRITICAL: API Keys and Secrets (NEVER push these!)
# ============================================================
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
secrets.json

# ============================================================
# Python Virtual Environments (large, auto-generated)
# ============================================================
venv/
env/
ENV/
.venv/
.virtualenv/
*.egg-info/
dist/
build/

# ============================================================
# Python Cache Files (auto-generated)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ============================================================
# IDE and Editor Files
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ============================================================
# Operating System Files
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================
# Logs and Temporary Files
# ============================================================
*.log
logs/
*.tmp
*.temp
temp/
tmp/

# ============================================================
# Audio/Video Files (can be large)
# ============================================================
*.wav
*.mp3
*.mp4
*.m4a
*.ogg
*.flac

# ============================================================
# Database Files
# ============================================================
*.db
*.sqlite
*.sqlite3

# ============================================================
# Node Modules (if you use any JS tools)
# ============================================================
node_modules/
package-lock.json
yarn.lock

# ============================================================
# Jupyter Notebook Checkpoints
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
# Testing and Coverage
# ============================================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# ============================================================
# Docker
# ============================================================
*.dockerfile
docker-compose.override.yml

# ============================================================
# Ngrok (temporary tunnel URLs)
# ============================================================
ngrok
ngrok.exe

# ============================================================
# Project Specific
# ============================================================
# Recordings and transcripts from testing
recordings/
transcripts/
test_audio/

# Any files with "secret" or "private" in the name
*secret*
*private*
*SECRET*
*PRIVATE*
