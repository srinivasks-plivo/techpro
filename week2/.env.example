# ============================================================
# Week 2: AI Agents - Environment Variables Template
# ============================================================
# This is a template file showing what API keys you need.
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Replace all placeholder values with your actual API keys
# 3. NEVER commit the .env file to git (it's in .gitignore)
# ============================================================

# ============================================================
# Day 1: LLM APIs
# ============================================================
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Day 2: Speech AI (STT & TTS)
# ============================================================

# Deepgram (Speech-to-Text)
# Get your key from: https://console.deepgram.com/
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs (Text-to-Speech)
# Get your key from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Specific ElevenLabs voice ID
# Find voices at: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================================
# Day 4: Plivo (Phone Calls)
# ============================================================
# Get credentials from: https://console.plivo.com/dashboard/
PLIVO_AUTH_ID=your_plivo_auth_id
PLIVO_AUTH_TOKEN=your_plivo_auth_token
PLIVO_PHONE_NUMBER=+1234567890

# ============================================================
# Day 5: LiveKit (Alternative Approach)
# ============================================================
# Get credentials from: https://cloud.livekit.io/
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# ============================================================
# Day 6: Railway Deployment
# ============================================================
# Port for the server (Railway sets this automatically)
PORT=5000

# ============================================================
# Database (from Week 1 - Vercel Postgres)
# ============================================================
# Get from: Vercel Dashboard → Storage → Your Postgres → .env.local
POSTGRES_URL=postgres://username:password@host:5432/database
POSTGRES_PRISMA_URL=postgres://username:password@host:5432/database?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgres://username:password@host:5432/database

# Alternative format
DATABASE_URL=postgres://username:password@host:5432/database

# ============================================================
# Optional: Monitoring and Analytics
# ============================================================
# If you want to add logging/monitoring later
SENTRY_DSN=
LOG_LEVEL=INFO

# ============================================================
# Development vs Production
# ============================================================
ENVIRONMENT=development
# Set to 'production' when deployed to Railway

# ============================================================
# IMPORTANT NOTES:
# ============================================================
#
# FREE TIERS:
# - OpenAI: Pay-as-you-go (need to add payment method)
# - Deepgram: $200 free credits
# - ElevenLabs: 10k characters/month free
# - Plivo: Pay-as-you-go (cheap for testing)
# - LiveKit: Free tier available
# - Railway: $5/month free credits
#
# SECURITY:
# - NEVER commit the .env file
# - NEVER share your API keys
# - Rotate keys if accidentally exposed
# - Use environment-specific keys (dev vs prod)
# ============================================================
